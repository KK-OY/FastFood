<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.sky.mapper.UserMapper">
    <insert id="add" useGeneratedKeys="true" keyProperty="id">
        insert into  user (openid,create_time) value (#{openid},#{createTime})
    </insert>

    <select id="GetUser" resultType="com.sky.entity.User">
        select id, openid, name, phone, sex, id_number, avatar, create_time from user where openid =#{openid}
    </select>
    <select id="getById" resultType="com.sky.entity.User">
        select * from user where id =#{id}
    </select>
    <select id="countByMap" resultType="java.lang.Integer">

            select count(id) from user
            <where>
                <if test="begin != null">
                    and create_time &gt;= #{begin}
                </if>
                <if test="end != null">
                    and create_time &lt;= #{end}
                </if>
            </where>
        </select>
    <select id="getTodayUser" resultType="java.lang.Integer">
        select COUNT(*) from user where create_time >= #{t}
    </select>
</mapper>
